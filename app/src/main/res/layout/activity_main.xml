<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:layoutDirection="rtl">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="OrShar AutoReboot" android:textSize="24sp" android:textStyle="bold"
        android:textColor="#1565C0" android:layout_marginTop="32dp" android:layout_marginBottom="8dp"/>
    <TextView android:id="@+id/statusText" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="בודק סטטוס..." android:textSize="16sp"
        android:layout_marginBottom="32dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="שעת אתחול יומית:" android:textSize="16sp" android:layout_marginBottom="8dp"/>
    <TimePicker android:id="@+id/timePicker" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:timePickerMode="spinner"
        android:layout_marginBottom="32dp"/>
    <Button android:id="@+id/saveBtn" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="שמור והפעל שירות"
        android:backgroundTint="#1565C0" android:layout_marginBottom="16dp"/>
    <Button android:id="@+id/deviceOwnerBtn" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="הצג פקודת Device Owner"
        android:backgroundTint="#455A64"/>
    <TextView android:id="@+id/infoText" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="" android:textSize="13sp"
        android:textColor="#666666" android:layout_marginTop="24dp" android:gravity="center"/>
</LinearLayout>
